# ─── Database (PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://pisster:pisster@postgres:5432/pisster?schema=public"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
NEXTAUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST="true"

# ─── CDN signing (nginx secure_link) ─────────────────────────────────
# Shared HMAC secret between the app and nginx. openssl rand -hex 32
CDN_SIGNING_SECRET="change-me-in-production"
# Public CDN host that serves protected video streams
CDN_BASE_URL="https://cdn.pisster.com"
# How long a minted stream URL stays valid (seconds)
CDN_URL_TTL_SECONDS="21600"

# ─── AWS S3 (video/thumbnail storage) ────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="pisster-media"
# Optional custom endpoint (leave blank for AWS)
S3_ENDPOINT=""

# ─── Redis (job queue + cache + rate limiting) ───────────────────────
REDIS_URL="redis://redis:6379"

# ─── Scrape worker VPN (required in prod — docker-compose.vpn.yml + Gluetun) ─
# Without this, the worker exits via the AWS datacenter IP and adult sites
# (esp. xHamster) return 520 / age-gates → empty downloads.
# Persist on the server so plain `docker compose up` keeps the VPN overlay:
#   COMPOSE_FILE=docker-compose.yml:docker-compose.vpn.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.vpn.yml
# NordVPN *service* credentials (NOT your login email/password):
# Nord Account → NordVPN → Manual setup → Service credentials
NORDVPN_OPENVPN_USER=""
NORDVPN_OPENVPN_PASSWORD=""
# Non-US countries avoid xHamster age-verification on datacenter IPs
NORDVPN_SERVER_COUNTRIES="Netherlands,Germany,France,Spain,Italy,Poland,Sweden,Norway,Finland,Denmark,Austria,Switzerland,Belgium,Portugal,Czech Republic,Romania,Hungary,Greece,Ireland,Slovakia,Croatia,Slovenia,Bulgaria,Lithuania,Latvia,Estonia,Luxembourg,Iceland,Canada,Japan,Australia,New Zealand,Singapore,Mexico,Brazil,Argentina,Chile,Colombia,South Africa,Israel,Turkey,India,Indonesia,Thailand,Vietnam,Philippines,Malaysia,Taiwan,South Korea"
# Docker bridge subnets allowed to bypass VPN (postgres, redis, S3 endpoint)
DOCKER_INTERNAL_SUBNETS="172.16.0.0/12,10.0.0.0/8,192.168.0.0/16"
# Gluetun HTTP proxy — worker uses this for xHamster/etc. ParadiseHill CDN is
# fetched direct (NordVPN exits get HTTP 503 from vN.paradisehill.cc).
SCRAPE_HTTP_PROXY="http://gluetun:8888"

# Worker download timeouts (seconds). Raise for slow links / large ParadiseHill films.
# SCRAPE_DOWNLOAD_TIMEOUT_SEC="3600"       # per wget part or single CDN file (default 900)
# SCRAPE_DOWNLOAD_LONG_TIMEOUT_SEC="7200"  # ffmpeg concat / yt-dlp (default 3600)
# SCRAPE_DOWNLOAD_CONCURRENCY="2"            # lower if parallel downloads saturate bandwidth
# ParadiseHill CDN rate-limits parallel connections (empty files / wget exit 8).
# SCRAPE_PH_CDN_CONCURRENCY="1"            # max simultaneous PH CDN downloads (default 1)
# SCRAPE_PH_CDN_RETRIES="3"                # retries per part when the CDN returns empty

# ─── Email (Gmail SMTP via nodemailer) ───────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="office@pisster.com"
SMTP_PASS="your-google-app-password"
MAIL_FROM="Pisster <office@pisster.com>"
ADMIN_NOTIFY_EMAIL="admin@example.com"

# Legal pages (2257 / DMCA) — set a real mailing address before going live in the US
LEGAL_CONTACT_EMAIL=""
LEGAL_CUSTODIAN_NAME=""
LEGAL_CUSTODIAN_ADDRESS=""

# ─── API keys (external integrations) ────────────────────────────────
# Generate with: openssl rand -base64 48
API_KEY_SECRET="change-me-in-production-must-be-at-least-32-chars"

# ─── Multi-tenant / domains ──────────────────────────────────────────
PRIMARY_DOMAIN="pisster.com"
ADMIN_SUBDOMAIN="admin"
# Admin host is admin.${ADMIN_BASE_DOMAIN} (not admin.pisster.com).
ADMIN_BASE_DOMAIN="sharlila.com"
# Space-separated names for nginx app server_name (no CDN).
SITE_SERVER_NAMES="pisster.com www.pisster.com fbbtube.com www.fbbtube.com sharlila.com www.sharlila.com admin.sharlila.com"
# CDN valid_referers for the shared cdn.pisster.com host.
NETWORK_REFERERS="pisster.com *.pisster.com fbbtube.com *.fbbtube.com sharlila.com *.sharlila.com"

# Localhost port the internal (dockerized) nginx binds to.
EDGE_HTTP_PORT="8080"

# ─── Ads (legacy env fallbacks — prefer per-site DB fields in Admin → Ad settings) ──
VAST_TAG_URL=""
AD_SKIP_SECONDS="5"
AD_MIN_VIEW_SECONDS="5"
AD_TIMEOUT_MS="8000"

# ExoClick display ad zone ids (leave blank to hide the slot)
EXO_ZONE_HOME=""
EXO_ZONE_UNDER_PLAYER=""

# ─── Google Analytics 4 (optional legacy fallback) ───────────────────────────
# Prefer per-site ids in Admin → Websites → SEO (Site.gaMeasurementId).
# This env var is only used when a site has no gaMeasurementId set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# Desktop Fullpage Interstitial — fullscreen overlay on /videos/[slug] only
EXO_ZONE_VIDEO_FULLSCREEN=""

# ─── AWS Bedrock (admin assistant only) ─────────────────────────────
# Used by /admin/assistant chat — NOT the video agent analysis model.
# Video agent model is chosen in the admin UI per run.
BEDROCK_MODEL_ID="anthropic.claude-haiku-4-5-20251001-v1:0"
# Comma-separated list shown in admin assistant settings (optional)
BEDROCK_MODELS="anthropic.claude-haiku-4-5-20251001-v1:0,anthropic.claude-sonnet-4-6"
# Uses AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY above (or instance role)

# ─── Video analyzer (Python service) ───────────────────────────────
# TwelveLabs direct API for Pegasus 1.5 segmentation (optional)
TWELVELABS_API_KEY=""
# Optional: restrict which models appear in the Video Agent dropdown.
# Omit to use the built-in default list (pegasus-1-5, pegasus-1-2, nova-2-lite).
# VIDEO_AGENT_MODELS="pegasus-1-5,pegasus-1-2,nova-2-lite"
# AWS account ID for Bedrock S3 bucketOwner (Pegasus/Nova video input)
AWS_ACCOUNT_ID=""
# Pipeline tuning
VIDEO_AGENT_CHUNK_SEC="180"
VIDEO_AGENT_USE_SCENE_CHUNKING="false"
VIDEO_AGENT_QUEUE_KEY="video-agent:queue"

# ─── Promo ad generator (Python service) ─────────────────────────────
PROMO_AD_QUEUE_KEY="promo-ad:queue"
PROMO_AD_BEDROCK_OUTPUT_PREFIX="s3://pisster-media/bedrock-reel-output/"
# Luma Ray 2 on Bedrock is us-west-2-only (Nova Reel uses AWS_REGION / us-east-1).
# PROMO_AD_LUMA_BEDROCK_REGION="us-west-2"
# Bundled brand lockup for FFmpeg overlay (PNG preferred; regenerate via scripts/export-brand-lockup.sh)
# PROMO_AD_BRAND_LOCKUP=/app/public/brand/pisster-lockup.png
# Comma-separated model ids shown in admin (clip-compose always included when configured)
# PROMO_AD_MODELS="clip-compose,nova-reel-1-1,luma-ray-2-540p,luma-ray-2-720p,kling-3-pro,veo-3-1-fast,runway-gen4-turbo,runway-gen4-5"
PROMO_AD_MODEL_CATALOG_VERSION="2026-07"
# External generative providers (optional — models hidden when key missing)
FAL_API_KEY=""
RUNWAY_API_KEY=""
GEMINI_API_KEY=""

# ─── ThePornDB performer images (optional) ───────────────────────────
# GraphQL at https://theporndb.net/graphql — token at https://theporndb.net/user/api-tokens
TPDB_API_KEY=""
# TPDB_API_URL="https://theporndb.net/graphql"
