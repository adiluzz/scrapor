# ─── Database (PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://pisster:pisster@postgres:5432/pisster?schema=public"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
NEXTAUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST="true"

# ─── CDN signing (nginx secure_link) ─────────────────────────────────
# Shared HMAC secret between the app and nginx. openssl rand -hex 32
CDN_SIGNING_SECRET="change-me-in-production"
# Public CDN host that serves protected video streams
CDN_BASE_URL="https://cdn.pisster.com"
# How long a minted stream URL stays valid (seconds)
CDN_URL_TTL_SECONDS="21600"

# ─── AWS S3 (video/thumbnail storage) ────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="pisster-media"
# Optional custom endpoint (leave blank for AWS)
S3_ENDPOINT=""

# ─── Redis (job queue + cache + rate limiting) ───────────────────────
REDIS_URL="redis://redis:6379"

# ─── Email (Gmail SMTP via nodemailer) ───────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="office@pisster.com"
SMTP_PASS="your-google-app-password"
MAIL_FROM="Pisster <office@pisster.com>"
ADMIN_NOTIFY_EMAIL="admin@example.com"

# ─── Multi-tenant / domains ──────────────────────────────────────────
PRIMARY_DOMAIN="pisster.com"
ADMIN_SUBDOMAIN="admin"

# Localhost port the internal (dockerized) nginx binds to. The HOST nginx
# reverse-proxies the Pisster domains to 127.0.0.1:${EDGE_HTTP_PORT}.
EDGE_HTTP_PORT="8080"

# ─── Ads (per-site default VAST tag; leave blank to disable ads) ──────
VAST_TAG_URL=""
AD_SKIP_SECONDS="5"
AD_MIN_VIEW_SECONDS="5"
AD_TIMEOUT_MS="8000"

# ExoClick display ad zone ids (leave blank to hide the slot)
EXO_ZONE_HOME=""
EXO_ZONE_UNDER_PLAYER=""

# ─── Google Analytics 4 (optional; loads only after age gate + cookie consent) ─
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# Desktop Fullpage Interstitial — fullscreen overlay on /videos/[slug] only
EXO_ZONE_VIDEO_FULLSCREEN=""

# ─── Assistant / Ollama (existing) ───────────────────────────────────
OLLAMA_VISION_MODEL="llava"
# OLLAMA_BASE_URL=http://127.0.0.1:11434/api
