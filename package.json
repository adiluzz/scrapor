{
  "name": "scrapor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev",
    "prestart": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "scrape": "node scripts/run-scrape.cjs",
    "scrape:playwright": "node scripts/run-scrape-playwright.cjs",
    "scrape:paradisehill": "node scripts/paradisehill-debug.cjs",
    "download-videos": "node scripts/download-videos.cjs",
    "download-videos:test": "LIMIT=2 node scripts/download-videos.cjs",
    "download-videos:fetch": "node scripts/download-videos-fetch.cjs",
    "download-videos:record": "node scripts/download-videos-record.cjs",
    "send-assistant-prompt": "node scripts/send-assistant-prompt.cjs",
    "save-screenshot": "node scripts/save-named-screenshot.cjs",
    "test-assistant": "bash scripts/test-assistant-e2e.sh",
    "ollama:docker": "bash scripts/start-ollama-docker.sh",
    "dev:video-assistant": "bash scripts/start-video-assistant.sh",
    "mcp:browser": "node mcp/browser-automation-server/server.mjs"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.105",
    "@ai-sdk/openai": "^4.0.4",
    "@aws-sdk/client-s3": "^3.1077.0",
    "@aws-sdk/s3-request-presigner": "^3.1077.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "@types/video.js": "^7.3.58",
    "ai": "^7.0.9",
    "bcryptjs": "^3.0.3",
    "cheerio": "1.0.0-rc.12",
    "graceful-fs": "^4.2.11",
    "ioredis": "^5.11.1",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "undici": "^8.2.0",
    "video.js": "^8.23.9",
    "videojs-contrib-ads": "^7.5.2",
    "zod": "^3.25.76"
  },
  "overrides": {
    "nodemailer": "$nodemailer",
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.16",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
