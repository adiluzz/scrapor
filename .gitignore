# ── Dependencies ──────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js / build output ────────────────────────────────────────────
.next/
out/
build/
dist/
next-env.d.ts
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Environment / secrets ─────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# ── Prisma (local dev database) ───────────────────────────────────────
prisma/dev.db
prisma/dev.db-journal
*.db
*.db-journal
*.sqlite
*.sqlite3

# ── Python (worker / scripts) ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Generated / downloaded media (never commit large binaries) ────────
# Anchored to repo root so they don't also ignore app routes like
# src/app/(site)/videos/ or src/app/api/.../uploads/.
/downloads/
/videos/
/library/
/uploads/
.ollama-local/

# ── Recordings & screenshots (runtime artifacts) ──────────────────────
.recordings/
.recordings-agent/
.recordings-assistant/
.screenshots/

# ── Logs ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ── Coverage / test ───────────────────────────────────────────────────
coverage/
.nyc_output/

# ── IDE / editor ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS junk ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.cloudfront-keys/
